<% cbv_applicant = @cbv_flow.cbv_applicant %>
<% agency = ClientAgencyConfig.instance[@cbv_flow.client_agency_id] %>
<%= f.fields_for :cbv_applicant, cbv_applicant do |f2| %>
  <% agency.applicant_attributes.select { |_, attr| attr.show_on_applicant_form }.each do |name, attr| %>
    <% case attr.form_field_type %>
    <% when "memorable_date" %>
      <%= f2.memorable_date name.to_sym,
          legend: agency_translation("cbv.applicant_informations.{agency}.fields.#{name}.prompt"),
          hint: agency_translation("cbv.applicant_informations.{agency}.fields.#{name}.help_text") %>
    <% when "date_picker" %>
      <%= f2.date_picker name.to_sym,
          label: agency_translation("cbv.applicant_informations.{agency}.fields.#{name}.prompt") %>
    <% else %>
      <%= f2.text_field name.to_sym,
          label: agency_translation("cbv.applicant_informations.{agency}.fields.#{name}.prompt"),
          hint: agency_translation("cbv.applicant_informations.{agency}.fields.#{name}.help_text") %>
    <% end %>
  <% end %>
<% end %>
