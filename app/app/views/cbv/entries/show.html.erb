<% title = t(".header") %>
<% content_for :title, title %>
<div data-controller="cbv-entry-page">
  <h1><%= title %></h1>

  <p><%= t(".subheader", agency_full_name: agency_translation("shared.agency_full_name")) %></p>

  <p><strong><em><%= t(".time_estimate") %></em></strong></p>

  <h2><%= t(".what_youll_do") %></h2>

  <ul class="usa-icon-list margin-top-3">
    <li class="usa-icon-list__item margin-bottom-3">
      <div class="usa-icon-list__icon">
        <svg class="usa-icon text-primary" aria-hidden="true" role="img">
          <use href="<%= asset_path("@uswds/uswds/dist/img/sprite.svg#search") %>"></use>
        </svg>
      </div>
      <div class="usa-icon-list__content">
        <h3 class="margin-bottom-1"><%= t(".step1") %></h3>
        <p><%= t(".step1_description") %></p>
        <p><em><%= t(".step1_note") %></em></p>
      </div>
    </li>
    <li class="usa-icon-list__item margin-bottom-3">
      <div class="usa-icon-list__icon">
        <svg class="usa-icon text-primary" aria-hidden="true" role="img">
          <use href="<%= asset_path("@uswds/uswds/dist/img/sprite.svg#check") %>"></use>
        </svg>
      </div>
      <div class="usa-icon-list__content">
        <h3 class="margin-bottom-1"><%= t(".step2") %></h3>
        <p><%= t(".step2_description", agency_full_name: agency_translation("shared.agency_full_name")) %></p>
        <p><em><%= t(".step2_note") %></em></p>
      </div>
    </li>
    <li class="usa-icon-list__item margin-bottom-3">
      <div class="usa-icon-list__icon">
        <svg class="usa-icon text-primary" aria-hidden="true" role="img">
          <use href="<%= asset_path("@uswds/uswds/dist/img/sprite.svg#send") %>"></use>
        </svg>
      </div>
      <div class="usa-icon-list__content">
        <h3 class="margin-bottom-1"><%= t(".step3") %></h3>
        <p><%= t(".step3_description", agency_acronym: agency_translation("shared.agency_acronym")) %></p>
      </div>
    </li>
  </ul>

  <div data-controller="cbv-attestation-check">
    <%= form_with(url: cbv_flow_entry_path, builder: UswdsFormBuilder) do |f| %>
      <span class="d-block"> <abbr title="required" class="usa-hint--required">*</abbr> Required </span>
      <%= f.check_box(:agreement, { label: agency_translation(".checkbox", agency_full_name: agency_translation("shared.agency_full_name")),
                                    required: true,
                                    data: {
                                      action: "cbv-entry-page#consent change->cbv-attestation-check#setButton",
                                      cbv_entry_page_target: "consentCheckbox",
                                      cbv_attestation_check_target: "attestationCheckbox",
                                      testid: "attestation-checkbox"
                                    }
      }) %>
      <%= f.submit t(".continue"), { "data-cbv-attestation-check-target": "submitButton" } %>
    <% end %>
  </div>

  <div class="divider margin-bottom-5"></div>

  <%= render AccordionComponent.new(id: "who_is_this_for-accordion", heading_level: 2, data_action: "click->cbv-entry-page#viewHelpText", data_section_identifier: "who_is_this_tool_for") do |accordion| %>
    <% accordion.with_title do %>
      <%= t(".who_is_this_for_title") %>
    <% end %>
    <% accordion.with_accordion_item do %>
      <%= t(".who_is_this_for_body") %>
    <% end %>
  <% end %>

  <%= render AccordionComponent.new(id: "what_if_I_cant_use_this-accordion", heading_level: 2, data_action: "click->cbv-entry-page#viewHelpText", data_section_identifier: "what_if_i_cant_use_this_tool") do |accordion| %>
    <% accordion.with_title do %>
      <%= t(".what_if_i_cant_use_this_title") %>
    <% end %>
    <% accordion.with_accordion_item do %>
      <%= t(".what_if_i_cant_use_this_body_1", agency_portal_name: agency_translation("shared.agency_portal_name")) %>
      <%= agency_translation(".what_if_i_cant_use_this_body_2_html", agency_url: current_agency.agency_contact_website, agency_portal_name: agency_translation("shared.agency_portal_name")) %>
    <% end %>
  <% end %>
</div>
