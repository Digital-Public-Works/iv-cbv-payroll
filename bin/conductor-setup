#!/usr/bin/env bash
# Conductor setup script: prepare the environment for this workspace.
# Run this once when opening a new workspace (or after switching branches).
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
APP_DIR="${REPO_ROOT}/app"
WORKSPACE_NAME="$(basename "$REPO_ROOT")"

# Use the shared development database (consistent API keys, seed data, etc.)
export DB_NAME="iv_cbv_payroll_development"

echo "==> Conductor workspace: ${WORKSPACE_NAME}"
echo "==> Database: ${DB_NAME} (shared)"
echo ""

# --- Symlink .env.local if a shared copy exists ---
SHARED_ENV="$HOME/.config/iv-cbv-payroll/.env.local"
TARGET_ENV="${APP_DIR}/.env.local"
if [ -f "$SHARED_ENV" ] && [ ! -e "$TARGET_ENV" ]; then
  ln -s "$SHARED_ENV" "$TARGET_ENV"
  echo "  [OK] Linked .env.local from ${SHARED_ENV}"
elif [ -f "$TARGET_ENV" ]; then
  echo "  [OK] .env.local already exists"
else
  echo "  [WARN] No .env.local found. Place one at ${SHARED_ENV} to share across workspaces."
fi
echo ""

# --- Check prerequisites ---
echo "==> Checking prerequisites..."

errors=0

if ! command -v rbenv >/dev/null 2>&1; then
  echo "  [MISSING] rbenv — install via: brew install rbenv"
  errors=$((errors + 1))
fi

if ! command -v nodenv >/dev/null 2>&1; then
  echo "  [MISSING] nodenv — install via: brew install nodenv"
  errors=$((errors + 1))
fi

if ! command -v pg_isready >/dev/null 2>&1; then
  echo "  [MISSING] postgresql — install via: brew install postgresql@12"
  errors=$((errors + 1))
fi

if [ $errors -gt 0 ]; then
  echo ""
  echo "Fix the above issues and re-run this script."
  exit 1
fi

echo "  [OK] rbenv, nodenv, postgresql found"

# --- Check Ruby version ---
cd "$APP_DIR"
EXPECTED_RUBY="$(cat .ruby-version)"
CURRENT_RUBY="$(ruby -e 'puts RUBY_VERSION' 2>/dev/null || echo 'none')"
if [ "$CURRENT_RUBY" != "$EXPECTED_RUBY" ]; then
  echo ""
  echo "==> Installing Ruby ${EXPECTED_RUBY}..."
  rbenv install --skip-existing "$EXPECTED_RUBY"
  eval "$(rbenv init -)"
fi
echo "  [OK] Ruby ${EXPECTED_RUBY}"

# --- Check Node version ---
EXPECTED_NODE="$(cat .node-version)"
CURRENT_NODE="$(node --version 2>/dev/null | sed 's/^v//' || echo 'none')"
if [ "$CURRENT_NODE" != "$EXPECTED_NODE" ]; then
  echo ""
  echo "==> Installing Node ${EXPECTED_NODE}..."
  nodenv install --skip-existing "$EXPECTED_NODE"
  eval "$(nodenv init -)"
fi
echo "  [OK] Node ${EXPECTED_NODE}"

# --- Install Ruby dependencies ---
echo ""
echo "==> Installing Ruby dependencies..."
gem install bundler --conservative --no-document >/dev/null 2>&1
bundle check >/dev/null 2>&1 || bundle install

# --- Install JS dependencies ---
echo ""
echo "==> Installing JS dependencies..."
npm install

# --- Ensure PostgreSQL is running ---
echo ""
echo "==> Checking PostgreSQL..."
if pg_isready -q 2>/dev/null; then
  echo "  [OK] PostgreSQL is running"
else
  echo "  Starting PostgreSQL..."
  brew services start postgresql@12 2>/dev/null || brew services start postgresql 2>/dev/null || true
  # Wait for it
  for i in $(seq 1 10); do
    if pg_isready -q 2>/dev/null; then break; fi
    sleep 1
  done
  if pg_isready -q 2>/dev/null; then
    echo "  [OK] PostgreSQL started"
  else
    echo "  [WARN] PostgreSQL may not be running. Start it manually."
  fi
fi

# --- Set up moto virtual environment (for local SQS) ---
echo ""
echo "==> Checking moto (local SQS)..."
VENV_DIR="${REPO_ROOT}/.venv"
if [ ! -d "$VENV_DIR" ]; then
  echo "  Creating Python venv at ${VENV_DIR}..."
  python3 -m venv "$VENV_DIR"
  source "$VENV_DIR/bin/activate"
  pip install --quiet 'moto[server]'
  echo "  [OK] moto installed"
else
  echo "  [OK] Python venv exists at ${VENV_DIR}"
fi

# --- Set local AWS/SQS env vars so Rails initializers don't hit real AWS ---
# (These match what's in app/.env but we need them before dotenv loads)
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_REGION=us-east-1
export AWS_SQS_ENDPOINT=http://localhost:3456
export AWS_SDK_LOAD_CONFIG=false
export AWS_CONFIG_FILE=/dev/null
export AWS_SHARED_CREDENTIALS_FILE=/dev/null
unset AWS_PROFILE
export DISABLE_RDS_IAM=true

# --- Migrate the shared database ---
echo ""
echo "==> Running migrations on ${DB_NAME}..."
export RAILS_ENV=development

# Create DB if it doesn't exist yet
if ! psql -lqt 2>/dev/null | cut -d \| -f 1 | grep -qw "$DB_NAME"; then
  echo "  Creating database..."
  bin/rails db:create 2>/dev/null || true
fi

bin/rails db:migrate
echo "  [OK] Database migrated"

# --- Seed if needed ---
RECORD_COUNT=$(bin/rails runner "puts User.where(is_service_account: true).count" 2>/dev/null || echo "0")
if [ "$RECORD_COUNT" = "0" ]; then
  echo ""
  echo "==> Seeding database..."
  bin/rails db:seed
  echo "  [OK] Database seeded"
fi

echo ""
echo "========================================="
echo "Setup complete!"
echo ""
echo "Run bin/conductor-start to start the dev server."
echo "========================================="
