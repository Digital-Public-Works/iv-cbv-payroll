#!/usr/bin/env bash
# Conductor start script: launch the dev server for this workspace.
# Assumes conductor-setup has already been run.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
APP_DIR="${REPO_ROOT}/app"

cd "$APP_DIR"

# Disable AWS SSO/RDS IAM for local dev
export AWS_CONFIG_FILE=/dev/null
export AWS_SHARED_CREDENTIALS_FILE=/dev/null
unset AWS_PROFILE
export DISABLE_RDS_IAM=true

echo "==> Starting dev server"
echo ""

# Ensure PostgreSQL is running
if ! pg_isready -q 2>/dev/null; then
  echo "WARNING: PostgreSQL doesn't seem to be running. Start it with:"
  echo "  brew services start postgresql@12"
  exit 1
fi

# Start the app via foreman (bin/dev)
exec ./bin/dev
