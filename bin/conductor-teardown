#!/usr/bin/env bash
# Conductor teardown script: clean up workspace-specific resources.
# The shared development database is NOT dropped — it's used by all workspaces.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
WORKSPACE_NAME="$(basename "$REPO_ROOT")"

echo "==> Tearing down workspace: ${WORKSPACE_NAME}"

# Clean up the moto venv if it exists
VENV_DIR="${REPO_ROOT}/.venv"
if [ -d "$VENV_DIR" ]; then
  rm -rf "$VENV_DIR"
  echo "  [OK] Removed Python venv"
fi

# Remove symlinked .env.local (don't delete the source)
TARGET_ENV="${REPO_ROOT}/app/.env.local"
if [ -L "$TARGET_ENV" ]; then
  rm "$TARGET_ENV"
  echo "  [OK] Removed .env.local symlink"
fi

echo ""
echo "  Note: Shared database (iv_cbv_payroll_development) was NOT dropped."
echo "  [OK] Teardown complete"
